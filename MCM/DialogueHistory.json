{
	"modName": "DialogueHistory",
	"displayName": "$modDisplayName",
	"description": "$modDescription",
	"saveFile": "Stentorious/DialogueHistory.ini",
	"minMCMVersion": 1.00,
	"minModVersion": 1.00,
	"requirements": [
		{ "type": "file", "file": "NVSE/plugins/scripts/gr_DialogueHistory.txt" }
	],
	"submenus": {
		"0": {
			"listTitle": "$modDisplayName",
			"pageTitle": "$modDisplayName",
			"active": 1,
			"columns": 1,
			"enable": 1,
			"options": {
				"1": {
					"title": "$General",
					"enable": 1,
					"type": 0
				},
				"2": {
					"title": "$DialogueHistory",
					"type": 5,
					"enable": 1,
					"mouse": "$DialogueHistoryMouse",
					"vars": [{ "form": "Goo1", "auxVar": "*DiaHist_INI", "key": 5, "configINI": "General:bDialogueHistory", "default": 1 }]
				},
				"3": {
					"title": "$EntryLimit",
					"type": 2,
					"enable": 1,
					"mouse": "$EntryLimitMouse",
					"vars": [{ "form": "Goo1", "auxVar": "*DiaHist_INI", "key": 0, "configINI": "General:iEntryLimit", "default": 250 }],
					"scale": { "valueDecimal": 0, "valueIncrement": 1, "valueMin": 0, "valueMax": 1000 }
				},
				"4": {
					"title": "$IgnoreNonPersistentNPCs",
					"enable": 1,
					"type": 5,
					"mouse": "$IgnoreNonPersistentNPCsMouse",
					"vars": [{ "form": "Goo1", "auxVar": "*DiaHist_INI", "key": 1, "configINI": "General:bIgnoreNonPersistentNPCs", "default": 1 }]
				},
				"5": {
					"title": "$IgnoreDuplicateLines",
					"enable": 1,
					"type": 5,
					"mouse": "$IgnoreDuplicateLinesMouse",
					"vars": [{ "form": "Goo1", "auxVar": "*DiaHist_INI", "key": 2, "configINI": "General:bIgnoreDuplicateLines", "default": 1 }]
				},
				"6": {
					"title": "$DeleteConformation",
					"enable": 1,
					"type": 5,
					"mouse": "$DeleteConformationMouse",
					"vars": [{ "form": "Goo1", "auxVar": "*DiaHist_INI", "key": 8, "configINI": "General:bDeleteConfirmation", "default": 1 }]
				},
				"8": {
					"title": "$Interface",
					"enable": 1,
					"type": 0
				},
				"9": {
					"title": "$ConversationTranscriptStyle",
					"type": 6,
					"enable": 1,
					"mouse": "$ConversationTranscriptStyleMouse",
					"vars": [ { "uiTrait": "HUDMainMenu/_DiaHist+TranscriptStyle", "configINI": "Interface:iConversationTranscriptStyle", "default": 0 } ],
					"textOff": "$FalloutNV",
					"textOn": "$Fallout76"
				},
				"10": {
					"title": "$ShowMenuButton",
					"enable": 1,
					"type": 5,
					"mouse": "$ShowMenuButtonMouse",
					"vars": [{ "uiTrait": "HUDMainMenu/_DiaHist+ShowButton", "configINI": "Interface:bShowMenuButton", "default": 1 }]
				},
				"11": {
					"title": "$NameColorPlayer",
					"type": 9,
					"enable": 1,
					"mouse": "$NameColorPlayerMouse",
					"vars": [
						{ "uiTrait": "HUDMainMenu/_DiaHist+SpkrRed_0", "configINI": "Interface:iPlayerRed", "default": 255 },
						{ "uiTrait": "HUDMainMenu/_DiaHist+SpkrGreen_0", "configINI": "Interface:iPlayerGreen", "default": 255 },
						{ "uiTrait": "HUDMainMenu/_DiaHist+SpkrBlue_0", "configINI": "Interface:iPlayerBlue", "default": 51 }
					]
				},
				"12": {
					"title": "$NameColorNPC",
					"type": 9,
					"enable": 1,
					"mouse": "$NameColorNPCMouse",
					"vars": [
						{ "uiTrait": "HUDMainMenu/_DiaHist+SpkrRed_1", "configINI": "Interface:iNPCRed", "default": 0 },
						{ "uiTrait": "HUDMainMenu/_DiaHist+SpkrGreen_1", "configINI": "Interface:iNPCGreen", "default": 204 },
						{ "uiTrait": "HUDMainMenu/_DiaHist+SpkrBlue_1", "configINI": "Interface:iNPCBlue", "default": 255 }
					]
				}
			}
		}
	}
}