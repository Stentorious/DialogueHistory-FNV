int	iKeyID

int	iMenuID
float xmlCursorPosX
float xmlCursorPosY

begin Function {iKeyID}

	; Ignore inputs in console
	if eval MenuMode 3
		return
	endif

	; StartMenu (Pause)
	if eval (iMenuID = GetActiveMenuMode) == 1013 && MenuMode 4 == 0

		; Prevent menu action while conflicting menus are open
		if eval GetUIFloatAlt "StartMenu\MCM\_Menu" == 1 || GetUIFloatAlt "StartMenu\_MAPMOConfig" == 1 || GetUIFloatAlt "StartMenu\B42NP\visible" == 1 || GetUIFloatAlt "StartMenu\MAPMO\AchievementsLog\_open" > 0
			return
		endif

		; Toggle Visibility
		if eval iKeyID == 35 && GetUIFloatAlt "StartMenu\_DiaHist+Search" != 1
			if eval GetUIFloatAlt "StartMenu\_DiaHist+Visible" == 0
				if eval GetUIFloatAlt "StartMenu\NOGLOW_BRANCH\main_container\_enabled" == 1
					if eval GetUIFloatAlt "StartMenu\_DiaHist+Init" == 1
						Call (CompileScript "DialogueHistory\RefreshMenu.gek")
					endif
					SetUIFloat "StartMenu\NOGLOW_BRANCH\main_container\_enabled" 0		; Settings options
					SetUIFloat "StartMenu\MCM\MCM_Trigger\target" 0						; MCM open
					SetUIFloat "StartMenu\B42NPause\B42NIcon\target" 0					; B42 open
					SetUIFloatAlt "StartMenu\_DiaHist+Visible" 1
					SetUIFloatAlt "StartMenu\MAPMO\Hotkeys\DialogueHistoryButton\_selected" 1
					DisableButton 8192
					PlaySound UIMenuOk 1

					; Show update message
					if eval Goo1.AuxVarGetFlt "*DiaHist_INI" 6
						MessageBoxExAlt ({int iButton} => "") (GetINIString "Strings:sHelpDialogueHistory" "Stentorious\Translate\DialogueHistory.ini")
						SetINIFloat "Mods:DialogueHistory" 100 "Stentorious\UpdateMessages.ini"
						Goo1.AuxVarSetFlt "*DiaHist_INI" 0 6
					endif

					return
				endif
			else
				StopSoundFromPath (Goo1.AuxVarGetStr "*DiaHist_Voiceline")
				SetUIFloatAlt "StartMenu\_DiaHist+Visible" 0
				SetUIFloatAlt "StartMenu\MAPMO\Hotkeys\DialogueHistoryButton\_selected" 0
				SetUIFloatAlt "StartMenu\NOGLOW_BRANCH\main_container\_enabled" 1
				SetUIFloatAlt "StartMenu\MCM\MCM_Trigger\target" 1
				SetUIFloatAlt "StartMenu\B42NPause\B42NIcon\target" 1
				CallAfter 0.2 ({} => EnableButton 8192) 1
				PlaySound UIMenuCancel 1
				return
			endif
		endif

		if eval GetUIFloatAlt "StartMenu\_DiaHist+Visible" == 0
			return
		endif

		; Tab
		if eval iKeyID == 15
			if eval GetUIFloatAlt "StartMenu\_DiaHist+Search" == 1
				if eval GetUIString "StartMenu\DialogueHistory\Search\_search_term" != ""
					SetUIFloatAlt "StartMenu\_DiaHist+Search" 2
				else
					ClickMenuButton "StartMenu#507"
				endif
			endif
			StopSoundFromPath (Goo1.AuxVarGetStr "*DiaHist_Voiceline")
			SetUIFloatAlt "StartMenu\_DiaHist+Visible" 0
			SetUIFloatAlt "StartMenu\MAPMO\Hotkeys\DialogueHistoryButton\_selected" 0
			SetUIFloatAlt "StartMenu\NOGLOW_BRANCH\main_container\_enabled" 1
			SetUIFloatAlt "StartMenu\MCM\MCM_Trigger\target" 1
			SetUIFloatAlt "StartMenu\B42NPause\B42NIcon\target" 1
			CallAfter 0.2 ({} => EnableButton 8192) 1
			PlaySound UIMenuCancel 1
			return
		endif

		; Ctrl + F (Search Bar)
		if eval iKeyID == 33 && (IsKeyPressed 29 2 || IsKeyPressed 157 2)
			if eval GetUIFloatAlt "StartMenu\_DiaHist+Search" != 1
				ClickMenuButton "StartMenu#506"
			else
				if eval GetUIString "StartMenu\DialogueHistory\Search\_search_term" != ""
					SetUIFloatAlt "StartMenu\_DiaHist+Search" 2
				else
					ClickMenuButton "StartMenu#507"
				endif
			endif
			return
		endif

		; Mouse Wheel
		xmlCursorPosX = (((GetUIFloatAlt "StartMenu\_screen_width") / (Goo1.AuxVarGetFlt "*_ScreenWidth")) * (GetCursorPos X)) - GetUIFloatAlt "StartMenu\DialogueHistory\x"
		xmlCursorPosY = (((GetUIFloatAlt "StartMenu\_screen_height") / (Goo1.AuxVarGetFlt "*_ScreenHeight")) * (GetCursorPos Y)) - GetUIFloatAlt "StartMenu\DialogueHistory\y"
		if eval xmlCursorPosX > GetUIFloatAlt "StartMenu\DialogueHistory\WindowDate\x" && xmlCursorPosX < (GetUIFloatAlt "StartMenu\DialogueHistory\WindowDate\x" + GetUIFloatAlt "StartMenu\DialogueHistory\WindowDate\width") && xmlCursorPosY > GetUIFloatAlt "StartMenu\DialogueHistory\WindowDate\y" && xmlCursorPosY < (GetUIFloatAlt "StartMenu\DialogueHistory\WindowDate\y" + GetUIFloatAlt "StartMenu\DialogueHistory\WindowDate\height")
			if eval iKeyID == 264
				ClickMenuTile "StartMenu\DialogueHistory\WindowDate\Scrollbar\scrollbar_vert_up"
			elseif eval iKeyID == 265
				ClickMenuTile "StartMenu\DialogueHistory\WindowDate\Scrollbar\scrollbar_vert_down"
			endif
		elseif eval xmlCursorPosX > GetUIFloatAlt "StartMenu\DialogueHistory\WindowDialogue\x" && xmlCursorPosX < (GetUIFloatAlt "StartMenu\DialogueHistory\WindowDialogue\x" + GetUIFloatAlt "StartMenu\DialogueHistory\WindowDialogue\width") && xmlCursorPosY > GetUIFloatAlt "StartMenu\DialogueHistory\WindowDialogue\y" && xmlCursorPosY < (GetUIFloatAlt "StartMenu\DialogueHistory\WindowDialogue\y" + GetUIFloatAlt "StartMenu\DialogueHistory\WindowDialogue\height")
			if eval iKeyID == 264
				ClickMenuTile "StartMenu\DialogueHistory\WindowDialogue\Scrollbar\scrollbar_vert_up"
			elseif eval iKeyID == 265
				ClickMenuTile "StartMenu\DialogueHistory\WindowDialogue\Scrollbar\scrollbar_vert_down"
			endif
		endif

	; DialogMenu
	elseif eval iMenuID == 1009

		; Toggle Visibility
		if eval iKeyID == 35
			if eval GetUIFloatAlt "DialogMenu\_DiaHist+Visible" == 0
				SetUIFloatAlt "DialogMenu\_DiaHist+Visible" 1
				PlaySound UIMenuOk 1
			else
				SetUIFloatAlt "DialogMenu\_DiaHist+Visible" 0
				PlaySound UIMenuCancel 1
			endif
		endif

		; Mouse Wheel
		if eval iKeyID == 264 || iKeyID == 265
			xmlCursorPosX = (((GetUIFloatAlt "DialogMenu\_screen_width") / (Goo1.AuxVarGetFlt "*_ScreenWidth")) * (GetCursorPos X)) - GetUIFloatAlt "DialogMenu\DialogueHistory\x"
			xmlCursorPosY = (((GetUIFloatAlt "DialogMenu\_screen_height") / (Goo1.AuxVarGetFlt "*_ScreenHeight")) * (GetCursorPos Y)) - GetUIFloatAlt "DialogMenu\DialogueHistory\y"
			if eval xmlCursorPosX > GetUIFloatAlt "DialogMenu\DialogueHistory\WindowDialogue\x" && xmlCursorPosX < (GetUIFloatAlt "DialogMenu\DialogueHistory\WindowDialogue\x" + GetUIFloatAlt "DialogMenu\DialogueHistory\WindowDialogue\width") && xmlCursorPosY > GetUIFloatAlt "DialogMenu\DialogueHistory\WindowDialogue\y" && xmlCursorPosY < (GetUIFloatAlt "DialogMenu\DialogueHistory\WindowDialogue\y" + GetUIFloatAlt "DialogMenu\DialogueHistory\WindowDialogue\height")
				if eval iKeyID == 264
					ClickMenuTile "DialogMenu\DialogueHistory\WindowDialogue\Scrollbar\scrollbar_vert_up"
				elseif eval iKeyID == 265
					ClickMenuTile "DialogMenu\DialogueHistory\WindowDialogue\Scrollbar\scrollbar_vert_down"
				endif
			endif
		endif

	endif

end