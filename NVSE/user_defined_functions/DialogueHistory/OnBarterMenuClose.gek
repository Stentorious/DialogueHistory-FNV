int	iMenuID

begin Function {iMenuID}

	if eval Goo1.AuxVarGetFlt "*DiaHist_State" 0 == 0 || Goo1.AuxVarSize "*DiaHist_ConvoLines" < 1 || GetActiveMenuMode != 0
		if eval iMenuID == 1009
			Goo1.AuxVarSetFlt "*DiaHist_State" 0 0
		endif
		return
	endif

	Call (CompileScript "DialogueHistory\OnDialogMenuClose.gek") 1009

end