int iIndex

array_var aJSON
string_var sSaveName

begin Function {iIndex}

	; Erase entry
	sSaveName = Goo1.AuxVarGetStr "*DiaHist_Save"
	aJSON = ReadFromJSON (sSaveName) "" 0 1
	ar_Erase aJSON iIndex
	WriteToJSON aJSON (sSaveName) "" 0 1 0

	Call (CompileScript "DialogueHistory\RefreshMenu.gek")

	aJSON = Ar_Null
	sv_Destruct sSaveName

end