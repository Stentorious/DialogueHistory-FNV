			</blue>
			<font> <copy src="io()" trait="_DH+Font" /> </font>
			<zoom> 100 </zoom>
			<justify> &left; </justify>
			<string> <copy src="parent()" trait="_name" /> </string>
		</text>

		<text name="Dialog">
			<_sound> Sound.ogg </_sound>
			<id> 508 </id>
			<visible> 1 </visible>
			<target> <copy src="parent()" trait="_speaker" /> </target>
