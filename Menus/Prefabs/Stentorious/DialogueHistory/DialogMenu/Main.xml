		<_total_height>
			<copy src="me()" trait="_height" />
			<add src="sibling(Entry)" trait="_total_height" />
		</_total_height>
		<_dialog> Dialogue </_dialog>

		<visible> 1 </visible>
		<locus> 1 </locus>
		<x> 0 </x>
