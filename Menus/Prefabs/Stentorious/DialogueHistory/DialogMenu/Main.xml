		</y>
		<clips> 1 </clips>

		<text name="Speaker">
			<visible> 1 </visible>
			<systemcolor>
				<copy src="parent()" trait="_speaker" />
				<copy src="io()" trait="_DH+SpkrSystemcolor_" />
			</systemcolor>
			<red>
				<copy src="parent()" trait="_speaker" />
